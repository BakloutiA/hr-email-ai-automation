      "id": "b5cc25a8-9d58-465a-84e4-22b6c4089169",
      "name": "Basic LLM Chain",
      "retryOnFail": true,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "c0e5dd01-c578-4024-b967-65d893b52945",
              "name": "candidateName",
              "value": "={{ JSON.parse($json.text.replace(/```json|```/g, '').trim()).candidateName }}",
