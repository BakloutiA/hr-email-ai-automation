      "parameters": {
        "promptType": "define",
        "text": "=You are an HR Assistant for EDEKA. Analyze the following incoming email body and extract the candidate's core information. \n\nProvide the output strictly in clean JSON format with these exact keys:\n- \"candidateName\"\n- \"candidateEmail\"\n- \"appliedPosition\"\n- \"storeLocation\"\n\nEmail Body:\n{{ $json.snippet}}",
        "batching": {}
      },
